# SITREP configuration. Copy to `.env` and adjust as needed.
# All environment variables are prefixed with SITREP_.

# --- Data location (created lazily under CWD) ---
SITREP_BASE_DIR=.sitrep

# --- LLM backend: auto | ollama | transformers | demo ---
SITREP_LLM_PROVIDER=auto

# Ollama (HTTP) backend
SITREP_OLLAMA_URL=http://localhost:11434
SITREP_OLLAMA_MODEL=llama3.1:8b
SITREP_OLLAMA_TIMEOUT=120

# HuggingFace Transformers backend (in-process)
SITREP_HF_LLM_MODEL=HuggingFaceTB/SmolLM-135M-Instruct
SITREP_LLM_MAX_NEW_TOKENS=256
SITREP_LLM_TEMPERATURE=0.2

# --- Embeddings ---
SITREP_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SITREP_EMBEDDING_DIM=384
SITREP_EMBEDDING_BATCH_SIZE=32

# --- Reranker ---
SITREP_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Retrieval / fusion ---
SITREP_TOP_K=5
SITREP_FUSION_WEIGHTS=0.34,0.33,0.33
SITREP_FUSION_LR=0.05
SITREP_CONFIDENCE_THRESHOLD=0.55

# --- Chunking ---
SITREP_CHUNK_SIZE=512
SITREP_CHUNK_OVERLAP=64
SITREP_MIN_CHUNK_SIZE=32

# --- PPO compression agent ---
SITREP_PPO_TOTAL_TIMESTEPS=10000
SITREP_PPO_LEARNING_RATE=0.0003
SITREP_PPO_N_STEPS=2048
SITREP_PPO_BATCH_SIZE=64
SITREP_PPO_GAMMA=0.99
SITREP_COMPRESSION_MIN=0.2
SITREP_COMPRESSION_MAX=0.8

# --- Schema promotion ---
SITREP_SCHEMA_PROMOTION_THRESHOLD=5

# --- Logging ---
SITREP_LOG_LEVEL=INFO
